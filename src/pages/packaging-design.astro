---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Packaging & Label Design | Vita Organica"
  description="Our in-house design team creates stunning, FDA-compliant supplement labels and packaging that make your brand stand out on shelves and online."
>
  <!-- ═══════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════ -->
  <section class="pd-hero">
    <div class="container">
      <div class="pd-hero-grid">
        <div class="pd-hero-content" data-reveal>
          <span class="section-eyebrow">Packaging & Design</span>
          <h1>
            Label Design That <span class="highlight">Sells</span> - By Our
            In-House Team.
          </h1>
          <p class="pd-hero-sub">
            Most manufacturers leave you to figure out design on your own. At
            Vita Organica, our dedicated in-house creative team works alongside
            you to craft labels and packaging that command shelf presence, meet
            FDA compliance, and reflect your brand's identity - all under one
            roof.
          </p>
          <div class="cta-row">
            <a href="/request-quote" class="btn btn-primary btn-lg"
              >Start Your Design Project</a
            >
            <a href="/manufacturing" class="btn btn-secondary"
              >View Manufacturing</a
            >
          </div>
        </div>

        <div class="pd-hero-visual" data-reveal>
          <div class="pd-hero-img">
            <img
              src="/images/design_team_hero.png"
              alt="Vita Organica's in-house design team collaborating on supplement label designs in a modern creative studio"
              width="1024"
              height="1024"
              fetchpriority="high"
            />
          </div>
          <div class="pd-hero-badge">
            <div class="badge-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 19l7-7 3 3-7 7-3-3z"></path>
                <path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"></path>
                <path d="M2 2l7.586 7.586"></path>
                <circle cx="11" cy="11" r="2"></circle>
              </svg>
            </div>
            <div>
              <div class="badge-title">In-House Team</div>
              <div class="badge-sub">Design + Compliance</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       IN-HOUSE DESIGN TEAM
       ═══════════════════════════════════════════════ -->
  <section class="team-section">
    <div class="container">
      <div class="team-grid">
        <!-- Content side -->
        <div class="team-content" data-reveal>
          <span class="section-eyebrow">Your Brand, Our Expertise</span>
          <h2>An In-House Creative Team Dedicated to Your Brand</h2>
          <p>
            Unlike most contract manufacturers who outsource label design - or
            skip it entirely - Vita Organica employs a full in-house creative
            team of seasoned graphic designers, branding specialists, and
            compliance experts. We don't just print labels; we create brand
            experiences that convert.
          </p>

          <div class="team-capabilities">
            <div class="capability">
              <div class="cap-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 19l7-7 3 3-7 7-3-3z"></path>
                  <path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"></path>
                  <path d="M2 2l7.586 7.586"></path>
                  <circle cx="11" cy="11" r="2"></circle>
                </svg>
              </div>
              <div>
                <h4>Custom Label Design</h4>
                <p>
                  Eye-catching labels tailored to your target market, from
                  minimalist wellness to bold sports nutrition.
                </p>
              </div>
            </div>

            <div class="capability">
              <div class="cap-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 7h-9"></path>
                  <path d="M14 17H5"></path>
                  <circle cx="17" cy="17" r="3"></circle>
                  <circle cx="7" cy="7" r="3"></circle>
                </svg>
              </div>
              <div>
                <h4>Brand Identity Systems</h4>
                <p>
                  Color palettes, typography, and visual guidelines that create a
                  cohesive brand family across your entire product line.
                </p>
              </div>
            </div>

            <div class="capability">
              <div class="cap-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                  <polyline points="9 12 11 14 15 10"></polyline>
                </svg>
              </div>
              <div>
                <h4>FDA-Compliant Labeling</h4>
                <p>
                  Every design passes through our regulatory team to ensure
                  Supplement Facts panels, claims, and disclosures meet all
                  requirements.
                </p>
              </div>
            </div>

            <div class="capability">
              <div class="cap-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
                  <line x1="8" y1="21" x2="16" y2="21"></line>
                  <line x1="12" y1="17" x2="12" y2="21"></line>
                </svg>
              </div>
              <div>
                <h4>3D Mockups & Renderings</h4>
                <p>
                  See your product before it's produced with photorealistic
                  mockups ready for your website, Amazon listings, and investor
                  decks.
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Image side -->
        <div class="team-image-block" data-reveal>
          <div class="team-image-main">
            <img
              src="/images/packaging_options.png"
              alt="Range of premium supplement packaging options including bottles, pouches, sachets, and boxes with custom label designs"
              width="1024"
              height="1024"
              loading="lazy"
            />
          </div>
          <div class="team-stat-pill">
            <div class="pill-num">500+</div>
            <div class="pill-label">Labels Designed</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       DESIGN PROCESS
       ═══════════════════════════════════════════════ -->
  <section class="design-process-section" aria-labelledby="design-process-title">
    <div class="container">
      <div class="process-grid">
        <!-- Left: sticky heading -->
        <div class="process-sticky">
          <span class="section-eyebrow">Our Design Process</span>
          <h2 id="design-process-title">From Brief to Print-Ready in Weeks</h2>
          <p>
            Our streamlined design workflow means you get professional,
            compliant packaging design without the back-and-forth of managing
            external agencies.
          </p>
          <a href="/request-quote" class="btn btn-primary">Get Started</a>
        </div>

        <!-- Right: scrollable steps -->
        <div class="process-steps" role="list" aria-label="Design process steps" data-reveal-stagger>
          <div class="process-step" role="listitem">
            <div class="step-track">
              <div class="step-num" aria-hidden="true">1</div>
              <div class="step-line"></div>
            </div>
            <div class="step-body">
              <h3>Brand Discovery & Briefing</h3>
              <p>
                We learn about your brand story, target audience, competitive
                landscape, and aesthetic preferences to define a clear creative
                direction.
              </p>
              <span class="step-duration">Day 1-2</span>
            </div>
          </div>

          <div class="process-step" role="listitem">
            <div class="step-track">
              <div class="step-num" aria-hidden="true">2</div>
              <div class="step-line"></div>
            </div>
            <div class="step-body">
              <h3>Concept Development & Moodboarding</h3>
              <p>
                Our designers present 2-3 visual directions with moodboards,
                color palettes, and typography options so you can choose the path
                that feels right.
              </p>
              <span class="step-duration">Days 3-5</span>
            </div>
          </div>

          <div class="process-step" role="listitem">
            <div class="step-track">
              <div class="step-num" aria-hidden="true">3</div>
              <div class="step-line"></div>
            </div>
            <div class="step-body">
              <h3>Label Design & Iterations</h3>
              <p>
                Your chosen concept is refined into a full label design with
                front panel, back panel, Supplement Facts, and all required
                elements. Includes up to 3 revision rounds.
              </p>
              <span class="step-duration">Days 5-10</span>
            </div>
          </div>

          <div class="process-step" role="listitem">
            <div class="step-track">
              <div class="step-num" aria-hidden="true">4</div>
              <div class="step-line"></div>
            </div>
            <div class="step-body">
              <h3>Compliance & Regulatory Review</h3>
              <p>
                Our compliance team reviews every claim, ingredient listing, and
                disclaimer to ensure your label meets FDA and FTC requirements
                before it goes to print.
              </p>
              <span class="step-duration">Days 10-12</span>
            </div>
          </div>

          <div class="process-step" role="listitem">
            <div class="step-track">
              <div class="step-num" aria-hidden="true">5</div>
              <div class="step-line"></div>
            </div>
            <div class="step-body">
              <h3>Print-Ready Files & Production Handoff</h3>
              <p>
                Final files are prepared in print-ready formats and seamlessly
                handed off to our production team - no file transfers, no
                miscommunication, no delays.
              </p>
              <span class="step-duration">Days 12-14</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       PACKAGING OPTIONS
       ═══════════════════════════════════════════════ -->
  <section class="packaging-section">
    <div class="container">
      <div class="section-header" data-reveal>
        <span class="section-eyebrow">Packaging Formats</span>
        <h2>Retail-Ready Packaging for Every Product</h2>
        <p class="section-subhead">
          Choose from a wide range of packaging formats. Our design team ensures
          your label works perfectly with every container type.
        </p>
      </div>

      <div class="packaging-grid" data-reveal-stagger>
        <div class="pkg-card">
          <div class="pkg-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M8 2h8l2 4H6l2-4z"></path>
              <path d="M6 6v14a2 2 0 002 2h8a2 2 0 002-2V6"></path>
              <line x1="12" y1="11" x2="12" y2="17"></line>
              <line x1="9" y1="14" x2="15" y2="14"></line>
            </svg>
          </div>
          <h3>Bottles & Jars</h3>
          <p>
            HDPE, PET, and glass options with custom wrap-around labels, shrink
            sleeves, or direct printing.
          </p>
        </div>

        <div class="pkg-card">
          <div class="pkg-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16v16H4z"></path>
              <path d="M4 4l4 4h8l4-4"></path>
              <line x1="4" y1="8" x2="20" y2="8"></line>
            </svg>
          </div>
          <h3>Boxes & Cartons</h3>
          <p>
            Custom-printed folding cartons for a premium unboxing experience.
            Perfect for gift sets and retail displays.
          </p>
        </div>

        <div class="pkg-card">
          <div class="pkg-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 2h12l2 6H4l2-6z"></path>
              <path d="M4 8v12a2 2 0 002 2h12a2 2 0 002-2V8"></path>
              <path d="M12 12v4"></path>
            </svg>
          </div>
          <h3>Stand-Up Pouches</h3>
          <p>
            Resealable pouches with full-panel printing, ideal for powders,
            protein mixes, and bulk supplements.
          </p>
        </div>

        <div class="pkg-card">
          <div class="pkg-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="6" width="18" height="12" rx="2"></rect>
              <path d="M3 12h18"></path>
              <path d="M9 6v12"></path>
              <path d="M15 6v12"></path>
            </svg>
          </div>
          <h3>Sachets & Stick Packs</h3>
          <p>
            Single-serve convenience packaging for on-the-go consumers. Full
            color printing with tear-notch options.
          </p>
        </div>

        <div class="pkg-card">
          <div class="pkg-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <path d="M12 8v4l3 3"></path>
            </svg>
          </div>
          <h3>Shrink Sleeves</h3>
          <p>
            360-degree full-coverage label wraps for maximum shelf visibility and
            tamper-evidence.
          </p>
        </div>

        <div class="pkg-card">
          <div class="pkg-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"></path>
              <polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
              <line x1="12" y1="22.08" x2="12" y2="12"></line>
            </svg>
          </div>
          <h3>Custom Kitting</h3>
          <p>
            Multi-product bundles and subscription box assembly with branded
            inserts, cards, and outer packaging.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       WHY IN-HOUSE?
       ═══════════════════════════════════════════════ -->
  <section class="inhouse-section">
    <div class="container">
      <div class="section-header" data-reveal>
        <span class="section-eyebrow">The In-House Advantage</span>
        <h2>Why Brands Choose Our Design Team Over Agencies</h2>
        <p class="section-subhead">
          Having design under the same roof as manufacturing isn't just
          convenient - it's a competitive edge.
        </p>
      </div>

      <div class="inhouse-grid" data-reveal-stagger>
        <div class="inhouse-card">
          <div class="inhouse-num">01</div>
          <h3>Supplement Industry Expertise</h3>
          <p>
            Our designers specialize exclusively in supplement and health product
            packaging. They understand regulatory nuances, shelf psychology, and
            consumer behavior in this space.
          </p>
        </div>

        <div class="inhouse-card">
          <div class="inhouse-num">02</div>
          <h3>Faster Turnaround</h3>
          <p>
            No middlemen. No waiting for external agency timelines. Our
            designers sit next to our production team, so your project moves at
            the speed of conversation.
          </p>
        </div>

        <div class="inhouse-card">
          <div class="inhouse-num">03</div>
          <h3>Compliance Built In</h3>
          <p>
            Every label goes through our regulatory team before it goes to
            print. No costly redesigns after launch because of a missed claim or
            incorrect Supplement Facts panel.
          </p>
        </div>

        <div class="inhouse-card">
          <div class="inhouse-num">04</div>
          <h3>Seamless Production Handoff</h3>
          <p>
            Design files go straight to our printing and production floor. No
            file compatibility issues, no third-party delays, no miscommunication
            between agencies and manufacturers.
          </p>
        </div>

        <div class="inhouse-card">
          <div class="inhouse-num">05</div>
          <h3>Cost-Effective Bundling</h3>
          <p>
            When you manufacture with us, design services are offered at
            preferred rates - significantly lower than hiring an external agency
            or freelancer.
          </p>
        </div>

        <div class="inhouse-card">
          <div class="inhouse-num">06</div>
          <h3>Line Extension Support</h3>
          <p>
            Launching new SKUs? Our team already knows your brand guidelines and
            can produce consistent, on-brand packaging for new products in days,
            not weeks.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       FINAL CTA
       ═══════════════════════════════════════════════ -->
  <section class="final-cta-section">
    <div class="container">
      <div class="final-cta-inner">
        <h2>Ready to Design Your Brand?</h2>
        <p>
          Tell us about your product and vision. Our design team will get back to
          you within 24 hours with a custom plan.
        </p>

        <div class="cta-steps">
          <div class="cta-step">
            <span class="cta-step-num">1</span>
            <span>Share Your Vision</span>
          </div>
          <span class="cta-arrow">→</span>
          <div class="cta-step">
            <span class="cta-step-num">2</span>
            <span>Get Design Concepts</span>
          </div>
          <span class="cta-arrow">→</span>
          <div class="cta-step">
            <span class="cta-step-num">3</span>
            <span>Launch Your Brand</span>
          </div>
        </div>

        <div class="cta-btn-row">
          <a href="/request-quote" class="btn btn-primary btn-lg"
            >Start Your Design Project</a
          >
          <a href="/manufacturing" class="btn btn-ghost">View Manufacturing</a>
        </div>

        <p class="cta-sub-note">
          Free design consultation included with every manufacturing quote.
        </p>
      </div>
    </div>
  </section>

  <!-- Scroll reveal script -->
  <script>
    (function () {
      const revealEls = document.querySelectorAll(
        "[data-reveal], [data-reveal-stagger]",
      );
      if ("IntersectionObserver" in window) {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("revealed");
                io.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12 },
        );
        revealEls.forEach((el) => io.observe(el));
      } else {
        revealEls.forEach((el) => el.classList.add("revealed"));
      }
    })();
  </script>
</BaseLayout>

<style>
  /* ═══════════════════════════════════════════════
     HERO
     ═══════════════════════════════════════════════ */
  .pd-hero {
    padding: var(--sp-20) 0 var(--sp-24);
    background: var(--color-white);
    position: relative;
    overflow: hidden;
  }

  .pd-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
        ellipse 60% 50% at 80% 40%,
        rgba(232, 50, 154, 0.04) 0%,
        transparent 70%
      ),
      radial-gradient(
        ellipse 40% 60% at 10% 20%,
        rgba(0, 184, 169, 0.05) 0%,
        transparent 60%
      );
    pointer-events: none;
  }

  .pd-hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-16);
    align-items: center;
    position: relative;
  }

  .pd-hero-content {
    max-width: 580px;
  }

  .pd-hero h1 {
    font-size: var(--text-6xl);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.03em;
    margin-bottom: var(--sp-6);
    color: var(--color-ink);
  }

  .pd-hero h1 .highlight {
    color: var(--color-magenta);
  }

  .pd-hero-sub {
    font-size: var(--text-lg);
    color: var(--color-ink-soft);
    line-height: 1.65;
    margin-bottom: var(--sp-8);
  }

  .pd-hero-visual {
    position: relative;
  }

  .pd-hero-img {
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }

  .pd-hero-img img {
    width: 100%;
    height: auto;
    display: block;
  }

  .pd-hero-badge {
    position: absolute;
    bottom: -20px;
    left: -20px;
    background: var(--color-white);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
    padding: var(--sp-4) var(--sp-5);
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    z-index: 10;
  }

  .badge-icon {
    width: 40px;
    height: 40px;
    border-radius: var(--radius);
    background: linear-gradient(
      135deg,
      var(--color-magenta) 0%,
      #d42a8e 100%
    );
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-white);
    flex-shrink: 0;
  }

  .badge-icon svg {
    width: 20px;
    height: 20px;
  }

  .badge-title {
    font-weight: 700;
    font-size: var(--text-sm);
    color: var(--color-ink);
  }

  .badge-sub {
    font-size: var(--text-xs);
    color: var(--color-ink-muted);
  }

  /* ═══════════════════════════════════════════════
     IN-HOUSE DESIGN TEAM
     ═══════════════════════════════════════════════ */
  .team-section {
    padding: var(--sp-24) 0;
    background: var(--color-surface);
  }

  .team-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: var(--sp-16);
    align-items: start;
  }

  .team-content h2 {
    margin-bottom: var(--sp-4);
  }

  .team-content > p {
    font-size: var(--text-lg);
    color: var(--color-ink-soft);
    line-height: 1.65;
    margin-bottom: var(--sp-10);
  }

  .team-capabilities {
    display: flex;
    flex-direction: column;
    gap: var(--sp-6);
  }

  .capability {
    display: flex;
    gap: var(--sp-4);
    align-items: flex-start;
  }

  .cap-icon {
    width: 44px;
    height: 44px;
    min-width: 44px;
    border-radius: var(--radius);
    background: var(--color-teal-light);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-teal);
    flex-shrink: 0;
  }

  .cap-icon svg {
    width: 22px;
    height: 22px;
  }

  .capability h4 {
    margin-bottom: var(--sp-1);
    font-size: var(--text-lg);
  }

  .capability p {
    font-size: var(--text-sm);
    color: var(--color-ink-soft);
    line-height: 1.6;
  }

  .team-image-block {
    position: relative;
  }

  .team-image-main {
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }

  .team-image-main img {
    width: 100%;
    height: auto;
    display: block;
  }

  .team-stat-pill {
    position: absolute;
    bottom: -16px;
