---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About Us | Vita Organica" description="Vita Organica was built to give supplement brands the manufacturing partner they deserve. Transparent, fast, and invested in your success.">
  
  <!-- ═══════════════════════════════════════════════
       HERO - Brand Foundation
       ═══════════════════════════════════════════════ -->
  <section class="hero hero-about">
    <div class="container">
      <div class="section-header" data-reveal>
        <span class="section-eyebrow">About Us</span>
        <h1>We're Not Just a Manufacturer. We're Your Brand's Foundation.</h1>
        <p class="section-subhead">
          Vita Organica was built for one reason: to give supplement brands the manufacturing partner they actually deserve. One that's transparent, fast, and as invested in your success as you are.
        </p>
        <p class="hero-description" style="max-width: 800px; margin: var(--sp-6) auto 0; color: var(--color-ink-soft); font-size: var(--text-lg);">
          We know what it feels like to have a great product idea and nowhere reliable to take it. That's exactly why we built a different kind of operation. A U.S.-based, FDA-registered, cGMP-compliant facility that helps brands come to life.
        </p>
      </div>
      
      <div class="cta-row" style="justify-content: center; margin-top: var(--sp-10);">
        <a href="/request-quote" class="btn btn-primary btn-lg" data-track="cta-click" data-cta-name="about-request">Request a Quote</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       OUR STORY
       ═══════════════════════════════════════════════ -->
  <section class="story-section bg-surface">
    <div class="container">
      <div class="story-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--sp-16); align-items: center;">
        <div class="story-content" data-reveal>
          <span class="section-eyebrow">Our Story</span>
          <h2>Vita Organica was born out of frustration with the status quo.</h2>
          <p style="margin-bottom: var(--sp-6); font-size: var(--text-lg); color: var(--color-ink-soft);">
            Starting with a commitment to clean sourcing, rigorous testing, and honest communication, we built a manufacturing operation from the ground up that we'd actually want to use ourselves.
          </p>
          <p>
            Today, we've helped many brands launch and scale, from first-time founders with a single SKU to established brands expanding their entire product lines.
          </p>
        </div>
        <div class="story-visual" data-reveal>
          <div class="about-visual-box" style="position: relative; height: 440px; border-radius: var(--radius-xl); overflow: hidden; box-shadow: var(--shadow-lg);">
             <img
              src="/images/hero_img_3.png"
              alt="State-of-the-art laboratory at Vita Organica"
              class="about-img"
              loading="lazy"
              style="width: 100%; height: 100%; object-fit: cover;"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       WHAT WE STAND FOR
       ═══════════════════════════════════════════════ -->
  <section class="values-section">
    <div class="container">
      <div class="section-header" data-reveal>
        <span class="section-eyebrow">What We Stand For</span>
        <h2>Integrity in Every Step</h2>
      </div>

      <div class="who-grid" data-reveal-stagger style="margin-top: var(--sp-12);">
        <!-- Transparency -->
        <div class="who-card">
          <div class="who-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
              <circle cx="12" cy="12" r="3"></circle>
            </svg>
          </div>
          <h3>Transparency over shortcuts</h3>
          <p>
            You'll always know exactly what's going into your product, where the ingredients are sourced, and what every step of the process costs. No hidden fees. No mystery ingredients.
          </p>
        </div>

        <!-- Quality -->
        <div class="who-card">
          <div class="who-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          </div>
          <h3>Quality that holds up under scrutiny</h3>
          <p>
            Every batch is manufactured in our facility and independently third-party tested. We meet FDA standards not because we have to, but because your customers trust depends on it.
          </p>
        </div>

        <!-- Speed -->
        <div class="who-card">
          <div class="who-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"></path>
            </svg>
          </div>
          <h3>Speed without sacrifice</h3>
          <p>
            Our average time to market is 60 days for white label products. We've built our processes to move fast without cutting corners because in this industry, you can't afford either delay or compromise.
          </p>
        </div>

        <!-- Partnership -->
        <div class="who-card">
          <div class="who-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"></path>
              <circle cx="9" cy="7" r="4"></circle>
              <path d="M23 21v-2a4 4 0 00-3-3.87"></path>
            </svg>
          </div>
          <h3>Partnership, not just production</h3>
          <p>
            We don't disappear after your first order. We stay on as your manufacturing partner, helping you iterate on formulas, scale up production, and add new SKUs as your brand grows.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       WHAT WE MAKE
       ═══════════════════════════════════════════════ -->
  <section class="make-section bg-surface">
    <div class="container">
      <div class="make-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--sp-12); align-items: center;">
        <div class="make-content" data-reveal>
          <span class="section-eyebrow">What We Make</span>
          <h2>Held to the Highest Standards</h2>
          <p style="margin-bottom: var(--sp-6);">
            From flavor-forward gummies and clean-label capsules to functional powders and specialty honey gels, we manufacture across six product formats all under one roof, all held to the same standards.
          </p>
          <p>
            Whether you need a fully custom formulation built from scratch, or a proven white label formula you can brand as your own, we have the capabilities and the team to get you there.
          </p>
          <div style="margin-top: var(--sp-8);">
            <a href="/manufacturing" class="btn btn-secondary" data-track="cta-click" data-cta-name="about-view-capabilities">View All Capabilities</a>
          </div>
        </div>
        <div class="make-visual" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--sp-4);">
            <div style="height: 200px; background: #eee; border-radius: var(--radius); overflow: hidden;">
                <img src="/images/hero_img_1.png" alt="Manufacturing process" style="width: 100%; height: 100%; object-fit: cover; opacity: 0.9;" />
            </div>
            <div style="height: 200px; background: #eee; border-radius: var(--radius); overflow: hidden; margin-top: var(--sp-8);">
                <img src="/images/hero_img_2.png" alt="Supplement bottling" style="width: 100%; height: 100%; object-fit: cover; opacity: 0.9;" />
            </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       WHO WE WORK WITH
       ═══════════════════════════════════════════════ -->
  <section class="inhouse-section">
    <div class="container">
      <div class="section-header" data-reveal>
        <span class="section-eyebrow">Who We Work With</span>
        <h2>Partners in Growth</h2>
        <p class="section-subhead">
          We work with a wide range of partners, and whatever stage you're at, we've designed our process to meet you there.
        </p>
      </div>

      <div class="inhouse-grid" data-reveal-stagger>
        <div class="inhouse-card">
          <div class="inhouse-num">01</div>
          <h3>First-Time Founders</h3>
          <p>Launching your first product and needing a transparent partner to guide you through the complexities of manufacturing.</p>
        </div>
        <div class="inhouse-card">
          <div class="inhouse-num">02</div>
          <h3>eCommerce Brands</h3>
          <p>Established brands looking to scale their catalog and expand their entire product lines with a reliable partner.</p>
        </div>
        <div class="inhouse-card">
          <div class="inhouse-num">03</div>
          <h3>Influencers & Creators</h3>
          <p>Building supplement lines around their communities and needing products their customers can trust.</p>
        </div>
        <div class="inhouse-card">
          <div class="inhouse-num">04</div>
          <h3>Agencies</h3>
          <p>Managing multiple client brands under one roof and requiring a versatile manufacturing partner.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       MADE IN THE USA
       ═══════════════════════════════════════════════ -->
  <section class="usa-section bg-ink" style="padding: var(--sp-24) 0; color: var(--color-white); text-align: center;">
    <div class="container">
      <div class="section-header" data-reveal style="margin-bottom: var(--sp-10);">
        <span class="section-eyebrow" style="color: var(--color-green);">Made in the USA</span>
        <h2 style="color: var(--color-white);">Built to Last.</h2>
        <p class="section-subhead" style="color: rgba(255,255,255,0.7); max-width: 800px;">
          Our facility is 100% U.S. based, which means tighter quality control, faster shipping, and smoother regulatory compliance. We're proud to manufacture domestically and we think your customers will be too.
        </p>
      </div>
      <div class="cta-row" style="justify-content: center;">
        <a href="/request-quote" class="btn btn-primary btn-lg" data-track="cta-click" data-cta-name="about-partner">Partner With Us Today</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .hero-about {
    padding: var(--sp-32) 0 var(--sp-20);
    text-align: center;
    background: linear-gradient(to bottom, #fff, var(--color-surface));
  }
  .hero-about h1 {
    max-width: 900px;
    margin: 0 auto var(--sp-6);
    line-height: 1.1;
  }
  .hero-description {
    line-height: 1.6;
  }
  .bg-surface {
    background-color: var(--color-surface);
  }
  .bg-ink {
    background-color: var(--color-ink);
  }
  .story-section, .values-section, .make-section, .inhouse-section {
    padding: var(--sp-24) 0;
  }

  /* ── Audience Section (Now Inhouse-style) ── */
  .inhouse-section {
    background: var(--color-ink);
    color: var(--color-white);
  }
  .inhouse-section .section-eyebrow {
    color: var(--color-green);
  }
  .inhouse-section .section-header h2 {
    color: var(--color-white);
  }
  .inhouse-section .section-subhead {
    color: rgba(255, 255, 255, 0.65);
  }

  .inhouse-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-top: var(--sp-12);
  }
  .inhouse-card {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-xl);
    padding: 2.5rem;
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
  }
  .inhouse-card:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.2);
    transform: translateY(-4px);
  }
  .inhouse-num {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 800;
    color: var(--color-green);
    margin-bottom: var(--sp-4);
    line-height: 1;
    opacity: 0.5;
  }
  .inhouse-card h3 {
    color: var(--color-white);
    font-size: 1.25rem;
    margin-bottom: var(--sp-3);
    letter-spacing: -0.02em;
  }
  .inhouse-card p {
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.6;
  }
  
  @media (max-width: 992px) {
    .story-grid, .make-grid {
      grid-template-columns: 1fr !important;
      gap: var(--sp-12);
    }
    .make-visual {
        order: -1;
    }
  }
  
  @media (max-width: 768px) {
    .hero-about {
      padding: var(--sp-20) 0;
    }
    .inhouse-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
