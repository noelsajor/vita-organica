---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found | Agency Master" description="The page you are looking for does not exist.">
  <main class="error-page" style="min-height: 70vh; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 2rem;">
    <h1 style="font-size: var(--text-6xl); color: var(--color-magenta); margin-bottom: var(--sp-4);">404</h1>
    <h2 style="font-size: var(--text-3xl); margin-bottom: var(--sp-6);">Oops! Page Not Found</h2>
    <p style="font-size: var(--text-lg); color: var(--color-ink-soft); max-width: 500px; margin-bottom: var(--sp-8);">
      We couldn't find the page you were looking for. It might have been moved or doesn't exist.
    </p>
    <a href="/" class="btn btn-primary" data-track="cta-click" data-cta-name="404-return-home">Return Home</a>
  </main>
</BaseLayout>
