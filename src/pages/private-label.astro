---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Private Label Supplement Manufacturing | Your Formula, Your Brand"
  description="Build a supplement brand with full intellectual property ownership. Custom formulations developed from scratch, exclusive to your brand."
>
  {/* ── HERO SECTION ── */}
  <section class="hero-pl">
    <div class="container">
      <div class="hero-grid">
        <div class="hero-content" data-reveal>
          <div class="badge">Private Label Manufacturing</div>
          <h1>Your Formula. Your Brand. <span class="highlight">100% Yours.</span></h1>
          <p class="hero-subtext">
            Build a supplement brand with full intellectual property ownership. Custom
            formulations developed from scratch, exclusive to you. Not a shared formula. 
            A product that is uniquely and defensibly yours.
          </p>
          <div class="cta-row">
            <a href="/request-quote" class="btn btn-primary btn-lg" data-track="cta-click" data-cta-name="pl-start">Start Your Custom Formula</a>
            <a href="#process" class="btn btn-secondary" data-track="cta-click" data-cta-name="pl-process">View the Process →</a>
          </div>
        </div>

        <div class="hero-visual" data-reveal>
          <div class="glance-card">
            <h3>Private Label at a Glance</h3>
            <ul class="glance-list">
              <li>
                <span class="icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                </span>
                <div>
                  <strong>Time to Market:</strong>
                  <span>8 – 12 Weeks</span>
                </div>
              </li>
              <li>
                <span class="icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
                </span>
                <div>
                  <strong>Formula Ownership:</strong>
                  <span>100% Yours</span>
                </div>
              </li>
              <li>
                <span class="icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                </span>
                <div>
                  <strong>Customization Level:</strong>
                  <span>Full</span>
                </div>
              </li>
              <li>
                <span class="icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                </span>
                <div>
                  <strong>Facility:</strong>
                  <span>cGMP · FDA Registered</span>
                </div>
              </li>
              <li>
                <span class="icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                </span>
                <div>
                  <strong>Testing:</strong>
                  <span>Third-Party Certified</span>
                </div>
              </li>
              <li>
                <span class="icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/><path d="M2 12h20"/></svg>
                </span>
                <div>
                  <strong>Origin:</strong>
                  <span>Made in the USA</span>
                </div>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ── COMPARISON SECTION ── */}
  <section class="comparison-section">
    <div class="container">
      <div class="section-header" data-reveal>
        <h2>Private Label vs. White Label — What's the Difference?</h2>
      </div>
      <div class="comparison-grid">
        <div class="comp-col active" data-reveal>
          <div class="comp-header">
            <h3>Private Label</h3>
            <span class="col-tag">YOU'RE HERE</span>
          </div>
          <p class="comp-intro">A formula developed exclusively for your brand. Custom ingredients, custom ratios, custom identity.</p>
          <ul class="comp-list">
            <li>Unique formula built from scratch for your brand</li>
            <li>Full intellectual property ownership</li>
            <li>Exclusive to you — not sold to other brands</li>
            <li>Custom flavors, ingredients, and delivery formats</li>
            <li>Deeper regulatory guidance and documentation</li>
            <li>8 – 12 week average timeline</li>
          </ul>
        </div>

        <div class="comp-col" data-reveal>
          <div class="comp-header">
            <h3>White Label</h3>
          </div>
          <p class="comp-intro">A proven, pre-made formula you brand as your own. Fastest path to market — ideal for rapid launches.</p>
          <ul class="comp-list">
            <li>Pre-existing, market-tested formula</li>
            <li>Shared formula base (your brand, not exclusive)</li>
            <li>Faster to launch — approximately 60 days</li>
            <li>Lower upfront development cost</li>
            <li>Limited customization options</li>
            <li>Great for validating demand quickly</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  {/* ── OWNERSHIP SECTION ── */}
  <section class="ownership-section">
    <div class="container">
      <div class="section-header" data-reveal>
        <span class="section-eyebrow">Full Ownership</span>
        <h2>Everything You Build Is Yours</h2>
        <p class="section-subhead">
          Private label manufacturing means you walk away with exclusive rights
          to your formula, not a shared base that any competitor can also buy.
        </p>
      </div>

      <div class="ownership-grid" data-reveal-stagger>
        <div class="feature-card">
          <div class="card-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
          </div>
          <h4>Proprietary Formula</h4>
          <p>Your formula is developed exclusively for your brand and locked to your account. It will never be sold or licensed to another company.</p>
        </div>

        <div class="feature-card">
          <div class="card-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
          </div>
          <h4>Brand Identity</h4>
          <p>Custom packaging, label design, and visual identity crafted to position your product distinctly in your market.</p>
        </div>

        <div class="feature-card">
          <div class="card-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M10 2v6l-4.5 8.2A4 4 0 009 22h6a4 4 0 003.5-5.8L14 8V2"/><path d="M8 8h8"/><path d="M9 16h6"/></svg>
          </div>
          <h4>Custom Ingredients & Ratios</h4>
          <p>Choose your ingredient stack, potency levels, and delivery format — from novel nootropic blends to certified organic botanicals.</p>
        </div>

        <div class="feature-card">
          <div class="card-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          </div>
          <h4>Full Documentation</h4>
          <p>Certificate of Analysis, stability data, ingredient sourcing records, and full regulatory documentation — all yours.</p>
        </div>

        <div class="feature-card">
          <div class="card-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
          </div>
          <h4>Competitive Protection</h4>
          <p>Because no other brand can access your exact formula, you build a defensible product moat that white label cannot offer.</p>
        </div>

        <div class="feature-card">
          <div class="card-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
          </div>
          <h4>Scalable IP Asset</h4>
          <p>A proprietary formula is a business asset. It adds real value to your brand equity, especially when raising capital or exploring acquisition.</p>
        </div>
      </div>
    </div>
  </section>

  {/* ── PROCESS SECTION ── */}
  <section class="process-section" id="process">
    <div class="container">
      <div class="process-grid">
        <!-- Left: sticky heading -->
        <div class="process-sticky" data-reveal>
          <span class="section-eyebrow">The Process</span>
          <h2>From Brief to Brand — 8 to 12 Weeks</h2>
          <p>
            Private label requires more time than white label because we're building
            something custom. Here's exactly what happens at each stage.
          </p>
          <a href="/request-quote" class="btn btn-primary" data-track="cta-click" data-cta-name="pl-start-custom">Start Your Custom Formula</a>
        </div>

        <!-- Right: scrollable steps -->
        <div class="process-steps" data-reveal-stagger>
          {[
            {
              step: "1",
              duration: "Week 1",
              title: "Discovery Strategy & Brief",
              content: "We begin with a deep-dive consultation: your target consumer, health claims, desired format, competitive positioning, and budget. This clarity prevents costly revisions later.",
              tags: ["Kick-off call", "Brand brief", "Budget alignment"]
            },
            {
              step: "2",
              duration: "Weeks 2–3",
              title: "R&D Custom Formulation Development",
              content: "Our formulation team builds your product from scratch — selecting and sourcing ingredients, optimizing dosages, and developing the flavor or form profile unique to your brand.",
              tags: ["Ingredient sourcing", "Dosage modeling", "Flavor development"]
            },
            {
              step: "3",
              duration: "Weeks 3–5",
              title: "Sampling Physical Sample Review & Iteration",
              content: "You receive physical samples of your product for sensory and quality review. We typically allow up to two rounds of refinement before finalizing the formula for production approval.",
              tags: ["Sample batch", "Sensory review", "Sign-off"]
            },
            {
              step: "4",
              duration: "Weeks 4–6",
              title: "Compliance Label Design & Regulatory Review",
              content: "Full FDA-compliant label development including supplement facts panel, claims review, and packaging compliance. We flag any regulatory concerns before they reach production.",
              tags: ["FDA label compliance", "Claims review", "Packaging design"]
            },
            {
              step: "5",
              duration: "Weeks 6–10",
              title: "Production Manufacturing & Quality Testing",
              content: "Full production run in our cGMP-certified, FDA-registered facility. Every batch undergoes rigorous in-house QA and third-party lab testing before it can ship.",
              tags: ["cGMP production", "In-process QA", "Lab testing"]
            },
            {
              step: "6",
              duration: "Weeks 10–12",
              title: "Delivery Fulfillment & Ongoing Partnership",
              content: "Your finished products are delivered, along with complete documentation. We stay on as your manufacturing partner — managing reorders, future SKUs, and formula evolutions as your brand scales.",
              tags: ["Delivery & handoff", "Documentation", "Growth roadmap"]
            }
          ].map(item => (
            <div class="process-step">
              <div class="step-track">
                <div class="step-num">{item.step}</div>
                <div class="step-line"></div>
              </div>
              <div class="step-body">
                <h3>{item.title}</h3>
                <p>{item.content}</p>
                <div class="tag-row">
                  {item.tags.map(tag => <span class="tag">{tag}</span>)}
                </div>
                <span class="step-duration">{item.duration}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  {/* ── WHAT WE MAKE SECTION ── */}
  <section class="formats-section">
    <div class="container">
      <div class="section-header" data-reveal>
        <span class="section-eyebrow">What We Make</span>
        <h2>Available in Every Format</h2>
        <p class="section-subhead">
          Your custom formula can be developed in any of our manufacturing formats.
        </p>
      </div>

      <div class="bento-grid-container" data-reveal-stagger>
        <!-- Gummies -->
        <div class="bento-item large">
          <div class="bento-content">
            <div class="tile-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"></path>
              </svg>
            </div>
            <h3>Gummies</h3>
            <p>Pectin-based, custom flavor, custom shape. The highest-demand format for consumer wellness brands.</p>
            <a href="/manufacturing/gummies" class="text-link">Explore Gummies →</a>
          </div>
          <div class="bento-bg"></div>
        </div>

        <!-- Capsules -->
        <div class="bento-item standard">
          <div class="bento-content">
            <div class="tile-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2v20M2 12h20L12 2z"></path>
              </svg>
            </div>
            <h3>Capsules</h3>
            <p>Vegetarian, HPMC, and gelatin options. Ideal for high-potency herbal, nootropic, and daily health formulas.</p>
            <a href="/manufacturing/capsules" class="text-link">Explore Capsules →</a>
          </div>
          <div class="bento-bg"></div>
        </div>

        <!-- Honey Gels -->
        <div class="bento-item standard">
          <div class="bento-content">
            <div class="tile-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 12h-4l-3 9L9 3l-3 9H2"></path>
              </svg>
            </div>
            <h3>Honey Gels</h3>
            <p>Advanced high-viscosity honey-based delivery systems for performance and wellness applications.</p>
            <a href="/manufacturing/gel" class="text-link">Explore Honey Gels →</a>
          </div>
          <div class="bento-bg"></div>
        </div>

        <!-- Powders -->
        <div class="bento-item standard">
          <div class="bento-content">
            <div class="tile-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path>
              </svg>
            </div>
            <h3>Powders</h3>
            <p>Scalable industrial blending and filling for proteins, pre-workouts, and health blends.</p>
            <a href="/manufacturing/powders" class="text-link">Explore Powders →</a>
          </div>
          <div class="bento-bg"></div>
        </div>

        <!-- Honey Spoons -->
        <div class="bento-item standard">
          <div class="bento-content">
            <div class="tile-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M13 2L3 14h9l-1 8L21 10h-9l1-8z"></path>
              </svg>
            </div>
            <h3>Honey Spoons</h3>
            <p>Innovative honey-based single-serve delivery formats for ultimate convenience and premium gifting.</p>
            <a href="/manufacturing/spoons" class="text-link">Explore Honey Spoons →</a>
          </div>
          <div class="bento-bg"></div>
        </div>
      </div>
    </div>
  </section>

  {/* ── PACKAGES SECTION ── */}
  <section class="packages-section">
    <div class="container">
      <div class="section-header" data-reveal>
        <span class="section-eyebrow">What's Included</span>
        <h2>Everything in Your Private Label Package</h2>
        <p class="section-subhead">
          Every private label engagement includes end-to-end support — no
          hidden scope, no surprise fees.
        </p>
      </div>

      <div class="packages-grid" data-reveal-stagger>
        {[
          { title: "Dedicated Project Manager", desc: "A single point of contact managing your timeline, vendors, and approvals from day one." },
          { title: "Custom Formulation from Scratch", desc: "Our R&D team develops your formula from the ground up, tailored to your target consumer and brand goals." },
          { title: "Physical Sample Rounds", desc: "Up to two rounds of physical samples for your review and approval before production begins." },
          { title: "FDA-Compliant Label Development", desc: "Full supplement facts panel, claims review, and regulatory documentation prepared by our compliance team." },
          { title: "Third-Party Lab Testing", desc: "Every batch tested by an independent, accredited lab for potency, purity, and contaminants." },
          { title: "Certificate of Analysis", desc: "Full CoA included with every production run — shareable with your customers and retail partners." },
          { title: "Ingredient Sourcing Transparency", desc: "Full visibility into where your ingredients come from — origin, supplier, and quality standards." },
          { title: "Exclusive Formula Lock", desc: "Your formula is registered exclusively to your brand and will never be made available to competitors." }
        ].map(item => (
          <div class="package-item">
            <span class="pkg-check-icon"></span>
            <div>
              <h4>{item.title}</h4>
              <p>{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ── WHO IT'S FOR SECTION ── */}
  <section class="inhouse-section">
    <div class="container">
      <div class="section-header" data-reveal>
        <span class="section-eyebrow">Who It's For</span>
        <h2>Built for Brands That Want to Stand Out</h2>
        <p class="section-subhead">
          Private label is the right path if differentiation, defensibility, and brand
          depth matter to you.
        </p>
      </div>

      <div class="inhouse-grid" data-reveal-stagger>
        <div class="inhouse-card">
          <div class="inhouse-num">01</div>
          <h3>Founders with a Unique Vision</h3>
          <p>You have a specific product concept — a novel ingredient stack, a targeted health outcome, or a gap in the market. White label won't get you there. This will.</p>
        </div>
        <div class="inhouse-card">
          <div class="inhouse-num">02</div>
          <h3>Scaling Brands Adding New SKUs</h3>
          <p>You've validated demand with white label and now need to own your formula to protect margins, raise capital, or negotiate retail partnerships with real IP behind the product.</p>
        </div>
        <div class="inhouse-card">
          <div class="inhouse-num">03</div>
          <h3>Health Practitioners & Clinicians</h3>
          <p>Nutritionists, functional medicine doctors, and wellness professionals launching practitioner-grade lines with clinical-backed ingredient choices and precise dosages.</p>
        </div>
        <div class="inhouse-card">
          <div class="inhouse-num">04</div>
          <h3>Influencers & Content Creators</h3>
          <p>You have the audience. A proprietary formula gives your product a story that a white label SKU never can — and positions it as a premium, authentic offering your community can trust.</p>
        </div>
      </div>
    </div>
  </section>

  {/* ── FINAL CTA SECTION ── */}
  <section class="final-cta-section">
    <div class="container">
      <div class="final-cta-inner">
        <h2>Ready to Build Something Uniquely Yours?</h2>
        <p>
          Tell us about your product vision and we'll respond with a custom production plan and quote
          within 24–48 hours.
        </p>

        <div class="cta-steps">
          <div class="cta-step">
            <span class="cta-step-num">1</span>
            <span>Share Your Vision</span>
          </div>
          <span class="cta-arrow">→</span>
          <div class="cta-step">
            <span class="cta-step-num">2</span>
            <span>Get Production Plan</span>
          </div>
          <span class="cta-arrow">→</span>
          <div class="cta-step">
            <span class="cta-step-num">3</span>
            <span>Launch Your Brand</span>
          </div>
        </div>

        <div class="cta-btn-row">
          <a href="/request-quote" class="btn btn-primary btn-lg" data-track="cta-click" data-cta-name="pl-request-quote">Request a Private Label Quote</a>
          <a href="/manufacturing" class="btn btn-ghost" data-track="cta-click" data-cta-name="pl-compare">Compare with White Label</a>
        </div>
        <p class="cta-sub-note">No commitment required. We'll respond within one business day.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Variables ── */
  :root {
    --section-pad: 100px;
  }

  /* ── Hero ── */
  .hero-pl {
    padding: 120px 0 80px;
    background: linear-gradient(135deg, var(--color-white) 0%, var(--color-surface-alt) 100%);
    position: relative;
    overflow: hidden;
  }
  .hero-pl::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 80% 20%, rgba(232, 50, 154, 0.05) 0%, transparent 60%);
    pointer-events: none;
  }
  .badge {
    display: inline-block;
    padding: 6px 16px;
    background: var(--color-magenta-light, #fdf2f8);
    color: var(--color-magenta);
    font-size: var(--text-xs);
    font-weight: 700;
    border-radius: var(--radius-pill);
    margin-bottom: var(--sp-6);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .hero-pl h1 {
    font-size: var(--text-6xl);
    line-height: 1.1;
    margin-bottom: var(--sp-6);
  }
  .highlight {
    color: var(--color-magenta);
  }
  .hero-subtext {
    font-size: var(--text-lg);
    color: var(--color-ink-soft);
    max-width: 600px;
    margin-bottom: var(--sp-8);
  }

  .glance-card {
    background: var(--color-white);
    padding: var(--sp-8);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
    border: 1px solid var(--color-border-light);
  }
  .glance-card h3 {
    margin-bottom: var(--sp-6);
    font-size: var(--text-xl);
  }
  .glance-list {
    display: grid;
    gap: var(--sp-5);
  }
  .glance-list li {
    display: flex;
    gap: var(--sp-4);
    align-items: center;
  }
  .glance-list .icon {
    width: 40px;
    height: 40px;
    background: var(--color-surface);
    color: var(--color-magenta);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .glance-list .icon svg {
    width: 20px;
    height: 20px;
  }
  .glance-list strong {
    display: block;
    font-size: var(--text-xs);
    color: var(--color-ink-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .glance-list span {
    font-weight: 600;
    color: var(--color-ink);
  }

  /* ── Comparison ── */
  .comparison-section {
    padding: var(--section-pad) 0;
    background: var(--color-white);
  }
  .comparison-grid {
    display: grid;
