---
import FormatTemplate from '../../components/manufacturing/FormatTemplate.astro';

const benefits = [
  {
    title: "Market-Leading Flavor Systems",
    description: "Our flavor chemists specialize in masking active ingredients while delivering premium, natural taste profiles that drive repeat purchases.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>`
  },
  {
    title: "Clean-Label Pectin Solutions",
    description: "We lead the industry in vegan-friendly, pectin-based gummy manufacturing, meeting the growing demand for non-GMO and organic-compliant products.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M2 12h20L12 2z"/></svg>`
  },
  {
    title: "Automated Precision Dosing",
    description: "Our high-speed starchless depositing technology ensures every gummy contains the exact ingredient levels your customers expect.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>`
  }
];

const customizationOptions = [
  { title: "Flavor Profiles", description: "From classic fruit to exotic botanical blends." },
  { title: "Custom Shapes", description: "Bears, cubes, or proprietary 3D-molding." },
  { title: "Functional Actives", description: "Vitamins, minerals, Nootropics, and Botanicals." },
  { title: "Dietary Targets", description: "Sugar-free, Vegan (Pectin), and Gelatin-based." },
  { title: "Natural Colors", description: "Vibrant hues derived from fruits and vegetables." },
  { title: "Functional Coatings", description: "Sanded, oiled, or acid-finished textures." }
];

const capabilities = [
  {
    title: "Multi-Vitamin Infusions",
    description: "Successful integration of daily essentials into stable, great-tasting delivery formats."
  },
  {
    title: "Botanical & Herbal Blends",
    description: "Advanced extraction integration for Ashwagandha, Elderberry, and custom wellness complexes."
  },
  {
    title: "Sugar-Free Specialization",
    description: "Formulations utilizing Allulose, Xylitol, and Stevia that maintain traditional mouthfeel and texture."
  }
];

const packagingOptions = [
  {
    title: "Retail Bottling",
    items: ["PET & HDPE Colors", "Child-Resistant Packaging", "Induction & Pressure Seals"]
  },
  {
    title: "Secondary Packaging",
    items: ["Custom Display Trays", "Master Shipping Cartons", "Environmentally Controlled Transit"]
  }
];

const processSteps = [
  { step: "01", title: "R&D Formulation", description: "Technical review and iterative flavor profiling.", duration: "2 Weeks" },
  { step: "02", title: "Pilot Validation", description: "Small-scale run to confirm texture and stability.", duration: "1 Week" },
  { step: "03", title: "Batch Production", description: "Starchless depositing and clean-room curing.", duration: "3-4 Weeks" },
  { step: "04", title: "Quality Analytics", description: "Third-party potency and microbial verification.", duration: "1 Week" }
];

const proofStats = [
  { num: "50M+", label: "Gummies Annually" },
  { num: "99.8%", label: "Batch Consistency" },
  { num: "400+", label: "Custom Formulas" },
  { num: "Zero", label: "Contamination Record" }
];

const faqs = [
  { question: "What is the MOQ for gummy manufacturing?", answer: "Our minimum order quantities typically start at 50,000 units per SKU, allowing emerging brands to scale with manageable initial investments." },
  { question: "Can you manufacture pectin (vegan) gummies?", answer: "Yes, we specialize in high-quality citrus pectin formulations that are 100% vegan and heat-stable." },
  { question: "How long does the formulation process take?", answer: "A typical R&D cycle for a new gummy formula takes 2-4 weeks, depending on the complexity of the active ingredients and flavor targets." },
  { question: "Do you offer sugar-free gummy options?", answer: "Absolutely. We utilize advanced sweeteners like Allulose and Monk Fruit to create sugar-free gummies with excellent texture." },
  { question: "What certifications does your facility hold?", answer: "Our manufacturing partners operate in cGMP-certified and FDA-registered facilities to ensure the highest safety standards." },
  { question: "Can you assist with custom gummy shapes?", answer: "Yes, we offer proprietary mold design services to create gummies in unique shapes that match your branding." },
  { question: "Are your ingredients third-party tested?", answer: "Every batch undergoes rigorous testing for purity, potency, and safety through accredited third-party laboratories." },
  { question: "What is the total time to market?", answer: "From final formulation approval and label design, typical production lead times are 8-10 weeks." }
];
---

<FormatTemplate
  formatName="Gummy"
  heroTitle="Premium Gummy Manufacturing Solutions"
  heroDescription="Scale your brand with industrial-grade gummy supplement manufacturing. From clean-label pectin formulations to proprietary flavor masking, we provide the technical expertise to transform complex active ingredients into market-ready delivery systems."
  canonical="https://vitaorganica.com/manufacturing/gummies"
  benefits={benefits}
  capabilities={capabilities}
  packagingOptions={packagingOptions}
  processSteps={processSteps}
  proofStats={proofStats}
  customizationOptions={customizationOptions}
  faqs={faqs}
/>
