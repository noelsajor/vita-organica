---
import FormatTemplate from '../../components/manufacturing/FormatTemplate.astro';

const benefits = [
  {
    title: "Flexible Capsule Platforms",
    description: "Support for a wide range of sizes (000 to 4) and materials, including HPMC (Vegetarian/Vegan), Gelatin, and Pullulan.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M2 12h20L12 2z"/></svg>`
  },
  {
    title: "High-Potency Loading",
    description: "Optimized powder blending and high-density filling allow for maximum active ingredient concentration per capsule.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>`
  },
  {
    title: "Advanced Bioavailability",
    description: "Utilizing delayed-release technology and precision particle engineering to ensure ingredients are absorbed efficiently.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`
  }
];

const customizationOptions = [
  { title: "Shell Material", description: "HPMC (Vegan), Bovine Gelatin, or Premium Pullulan options." },
  { title: "Standard Sizing", description: "Complete range from 000 (largest) down to size 4 (smallest)." },
  { title: "Color Matching", description: "Custom translucent or opaque non-GMO color patterns." },
  { title: "Delayed Release", description: "Acid-resistant shells for targeted intestinal ingredient delivery." },
  { title: "Band Sealing", description: "Added security and oxygen barrier with liquid-tight sealing." },
  { title: "Custom Printing", description: "Edible-ink branding or dosage identifiers on the shell." }
];

const capabilities = [
  {
    title: "Complex Botanical Blending",
    description: "Homogeneous mixing of diverse herbal extracts for consistent cross-batch potency."
  },
  {
    title: "Micro-Dosage Precision",
    description: "Specialized equipment for accurate measurement of ultra-low dose active ingredients."
  },
  {
    title: "Beads-in-Capsule (DR)",
    description: "Delayed-release beadlet technology for multi-phase nutrient delivery systems."
  }
];

const packagingOptions = [
  {
    title: "Bottle Solutions",
    items: ["Glass & Plastic Jars", "UV-Protective Tints", "Tamper-Evident Lidding"]
  },
  {
    title: "Unit-Dose Blistering",
    items: ["Cold-Form Foil", "PVC/PVDC Blisters", "Child-Resistant Packaging"]
  }
];

const processSteps = [
  { step: "01", title: "Technical Review", description: "Analysis of ingredient compatibility and capacity.", duration: "1 Week" },
  { step: "02", title: "Bulk Blending", description: "Precision mixing in climate-controlled environments.", duration: "1 Week" },
  { step: "03", title: "Encapsulation", description: "High-speed filling with automated quality check.", duration: "2 Weeks" },
  { step: "04", title: "Analytical Testing", description: "Comprehensive lab verification for purity and dose.", duration: "1 Week" }
];

const proofStats = [
  { num: "1B+", label: "Capsules Manufactured" },
  { num: "99.9%", label: "Dosing Accuracy" },
  { num: "24Hr", label: "QA Lab Turnaround" },
  { num: "CGMP", label: "Certified Environment" }
];

const faqs = [
  { question: "What is the MOQ for capsule manufacturing?", answer: "Standard MOQs for capsules start at 50,000 - 100,000 units per run." },
  { question: "Do you offer vegetarian capsule options?", answer: "Yes, we prioritize HPMC vegetarian capsules for clean-label brands." },
  { question: "What capsule sizes do you support?", answer: "We support all standard industry sizes, including 000, 00, 0, 1, 2, 3, and 4." },
  { question: "Can you manufacture delayed-release capsules?", answer: "Yes, we utilize acid-resistant shell technology to ensure delivery to the small intestine." },
  { question: "What is the typical fill weight for a size 00 capsule?", answer: "Typically, a size 00 capsule holds between 540mg and 1090mg depending on powder density." },
  { question: "Do you offer custom capsule colors?", answer: "Yes, we can provide custom colors and even two-tone capsule shells to match your branding." },
  { question: "Can you assist with complex formulations?", answer: "Our R&D team can help optimize blends for flowability and potency within the capsule shell." },
  { question: "What is the turnaround time for a capsule production run?", answer: "Standard lead times are 7-10 weeks from the receipt of raw materials." }
];
---

<FormatTemplate
  formatName="Capsule"
  heroTitle="Precision Capsule Manufacturing"
  heroDescription="Leverage pharmaceutical-grade encapsulation technology to power your supplement brand. Our diverse material options and advanced powder engineering ensure consistent dose delivery and maximum ingredient stability for clinical and retail success."
  canonical="https://vitaorganica.com/manufacturing/capsules"
  benefits={benefits}
  capabilities={capabilities}
  packagingOptions={packagingOptions}
  processSteps={processSteps}
  proofStats={proofStats}
  customizationOptions={customizationOptions}
  faqs={faqs}
/>
