---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { client, isConfigured } from '../../lib/sanity/client';
import { allPostsQuery } from '../../lib/sanity/queries';

let posts = [];
let error = null;

if (isConfigured) {
  try {
    posts = await client.fetch(allPostsQuery);
  } catch (e) {
    error = "Failed to fetch posts from Sanity.";
  }
} else {
  error = "Sanity is not configured. Please add SANITY_PROJECT_ID to your .env file.";
}
---

<BaseLayout title="Blog | Vita Organica" description="Insights and news from the world of supplement manufacturing.">
  <section class="blog-header" style="padding: var(--sp-20) 0; background: var(--color-surface);">
    <div class="container">
      <div class="section-header">
        <span class="section-eyebrow">Our Blog</span>
        <h1>Latest Insights</h1>
        <p class="section-subhead">Expert advice on formulation, compliance, and scaling your supplement brand.</p>
      </div>
    </div>
  </section>

  <section class="blog-posts" style="padding: var(--sp-20) 0;">
    <div class="container">
      {error && (
        <div class="dev-message" style="padding: 2rem; background: var(--color-green-light); border-radius: var(--radius-lg); text-align: center;">
          <p style="color: var(--color-ink); font-weight: 600;">{error}</p>
          <p style="font-size: var(--text-sm); margin-top: 1rem; color: var(--color-ink-soft);">This message is only visible during development or when Sanity is not connected.</p>
        </div>
      )}

      {!error && posts.length === 0 && (
        <p style="text-align: center; color: var(--color-ink-soft);">No posts found.</p>
      )}

      {!error && posts.length > 0 && (
        <div class="blog-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: var(--sp-8);">
          {posts.map((post) => (
            <article class="blog-card" style="background: var(--color-white); border-radius: var(--radius-lg); overflow: hidden; border: 1px solid var(--color-border-light); transition: transform var(--dur);">
              <a href={`/blog/${post.slug.current}`} style="display: block;">
                {post.mainImage && (
                  <img src={post.mainImage.asset._ref} alt={post.mainImage.alt || ""} style="width: 100%; height: 240px; object-fit: cover;" />
                )}
                <div class="blog-card-content" style="padding: var(--sp-6);">
                  <div class="blog-meta" style="font-size: var(--text-xs); color: var(--color-teal); margin-bottom: var(--sp-2); font-weight: 600;">
                    {new Date(post.publishedAt).toLocaleDateString()} • {post.categories?.join(', ')}
                  </div>
                  <h3 style="margin-bottom: var(--sp-3);">{post.title}</h3>
                  <p style="font-size: var(--text-sm); color: var(--color-ink-soft);">{post.excerpt}</p>
                  <span class="text-link" style="margin-top: var(--sp-4);">Read More →</span>
                </div>
              </a>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
