---
import BaseLayout from "../layouts/BaseLayout.astro";
import LeadFunnel from "../components/LeadFunnel.astro";
---

<BaseLayout 
  title="Request a Quote | Vita Organica" 
  description="Get a custom manufacturing estimate for your supplement project. From gummies to capsules, witness the speed of our technical discovery process."
>
  <div class="quote-page-wrapper">
    <div class="container">
      <div class="quote-header" data-reveal>
        <h1>Request Your Custom Quote</h1>
        <p>Complete the form below to share your project requirements and schedule a technical discovery call.</p>
      </div>
      
      <div class="funnel-section" data-reveal>
        <LeadFunnel />
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .quote-page-wrapper {
    padding: 80px 0;
    background-color: var(--color-surface);
    min-height: 80vh;
  }

  .quote-header {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 48px;
  }

  .quote-header h1 {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    color: var(--color-ink);
    margin-bottom: 16px;
    font-weight: 800;
  }

  .quote-header p {
    font-size: var(--text-lg);
    color: var(--color-ink-soft);
  }

  .funnel-section {
    max-width: 800px;
    margin: 0 auto;
    background: var(--color-white);
    padding: 40px;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    border: 1px solid var(--color-border-light);
  }

  @media (max-width: 768px) {
    .quote-page-wrapper {
      padding: 48px 0;
    }
    
    .quote-header h1 {
      font-size: var(--text-3xl);
    }

    .funnel-section {
      padding: 24px;
    }
  }
</style>
