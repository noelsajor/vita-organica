---
interface Props {
  format?: string;
}

const { format = "" } = Astro.props;
---

<div class="lead-funnel-container" id="lead-funnel">
  {/* Form Card */}
  <div class="lead-form-card funnel-card" id="form-card">
    <h3>Get a Custom Quote</h3>
    <p>Complete the details below to unlock our team's calendar for a discovery call.</p>

    <form id="funnel-form" class="funnel-form">
      <!-- Honeypot for spam protection -->
      <input type="text" name="b_name" tabindex="-1" autocomplete="off" style="display: none;" aria-hidden="true" />
      
      <div class="form-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
        <div class="form-group" style="margin-bottom: 0;">
          <label for="funnel-name">Full Name</label>
          <input type="text" id="funnel-name" name="name" placeholder="John Doe" required />
        </div>
        <div class="form-group" style="margin-bottom: 0;">
          <label for="funnel-email">Work Email</label>
          <input type="email" id="funnel-email" name="email" placeholder="john@brand.com" required />
        </div>
      </div>

      <div class="form-group">
        <label for="funnel-company">Company Name</label>
        <input type="text" id="funnel-company" name="company" placeholder="Your Brand Ltd" required />
      </div>

      <div class="form-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
        <div class="form-group" style="margin-bottom: 0;">
          <label for="funnel-format">Manufacturing Format</label>
          <select id="funnel-format" name="format">
            <option value="gummies" selected={format === 'gummies'}>Gummies</option>
            <option value="capsules" selected={format === 'capsules'}>Capsules</option>
            <option value="soft-gels" selected={format === 'soft-gels'}>Soft Gels</option>
            <option value="gel" selected={format === 'gel'}>Specialty Gels</option>
            <option value="powders" selected={format === 'powders'}>Powders</option>
            <option value="spoons" selected={format === 'spoons'}>Stick Packs</option>
            <option value="other">Other / Not Sure</option>
          </select>
        </div>
        <div class="form-group" style="margin-bottom: 0;">
          <label for="funnel-quantity">Estimated Quantity</label>
          <input type="text" id="funnel-quantity" name="quantity" placeholder="e.g. 5,000 units" />
        </div>
      </div>

      <div class="form-group">
        <label for="funnel-timeline">Project Timeline</label>
        <select id="funnel-timeline" name="timeline">
          <option value="immediate">Immediate (ASAP)</option>
          <option value="1-3-months">1-3 Months</option>
          <option value="3-6-months">3-6 Months</option>
          <option value="planning">Just Planning / Research</option>
        </select>
      </div>

      <button type="submit" class="btn btn-primary btn-full" style="margin-top: 8px;">View Calendar & Get Quote</button>
      <p class="privacy-note" style="text-align: center; margin-top: 12px; font-size: var(--text-xs); color: var(--color-ink-muted);">
        Your data is secure. We use it only to prepare your custom estimate.
      </p>
    </form>
  </div>

  <div id="success-container" style="display: none; text-align: center; padding: 3rem 1rem;">
    <div style="width: 64px; height: 64px; background: var(--color-green); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem;">
      <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" style="width: 32px; height: 32px;">
        <polyline points="20 6 9 17 4 12"></polyline>
      </svg>
    </div>
    <h2>Request Received!</h2>
    <p style="max-width: 480px; margin: 0 auto 2rem; color: var(--color-ink-soft);">Our team will review your project details and reach out within 1 business day with a custom quote.</p>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const funnelForm = document.getElementById('funnel-form');
    const formCard = document.getElementById('form-card');
    const successContainer = document.getElementById('success-container');

    if (funnelForm) {
      funnelForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const fd = new FormData(funnelForm as HTMLFormElement);

        await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            type: 'quote',
            b_name: fd.get('b_name'),
            name: fd.get('name'),
            email: fd.get('email'),
            company: fd.get('company'),
            format: fd.get('format'),
            quantity: fd.get('quantity'),
            timeline: fd.get('timeline'),
          }),
        }).catch(() => {});

        formCard.style.display = 'none';
        successContainer.style.display = 'block';
        successContainer.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    }
  });
</script>

<style>
  .lead-funnel-container {
    width: 100%;
    margin: 0 auto;
  }
  
  .funnel-card {
    max-width: 600px;
    margin: 0 auto;
  }

  @media (max-width: 640px) {
    .form-grid {
      grid-template-columns: 1fr !important;
    }
  }
</style>
