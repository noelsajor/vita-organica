---
// src/components/manufacturing/sections/FormatQuality.astro
const standards = [
  { title: "Quality-first manufacturing practices", description: "Rigorous cGMP protocols applied to every production run." },
  { title: "Third-party testing options", description: "Validation through independent labs for potency and purity." },
  { title: "Batch consistency checks", description: "Advanced analytics ensuring every unit meets specification." },
  { title: "Traceable sourcing", description: "Full transparency on ingredient origins and chain of custody." }
];
---

<section class="who-section" style="padding: 80px 0; background: var(--color-surface-alt);">
  <div class="container">
    <div class="section-header" style="text-align: center;">
      <span class="section-eyebrow">Quality & Compliance</span>
      <h2>Trusted Manufacturing Standards</h2>
    </div>
    <div class="who-grid">
      {standards.map(item => (
        <div class="who-card" style="background: white;">
          <div class="who-icon" style="color: var(--color-teal);">
             <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
          </div>
          <h3 style="font-size: 1.1rem; margin-bottom: 0.5rem;">{item.title}</h3>
          <p style="font-size: 0.9rem;">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
