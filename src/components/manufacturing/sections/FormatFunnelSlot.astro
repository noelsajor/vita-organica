---
import LeadFunnel from '../../LeadFunnel.astro';

interface Props {
  formatName: string;
}

const { formatName } = Astro.props;
---

<section id="consultation" class="lead-capture-section">
  <div class="container">
    <div class="lead-grid">
      
      <div class="lead-content" data-reveal>
        <span class="section-eyebrow">Fast Turnaround</span>
        <h2>Get a Custom Quote for {formatName}</h2>
        <p>Tell us about your project and our team will get back to you with a detailed breakdown including MOQ, pricing, and an exact production timeline.</p>

        <ul class="guide-checklist">
          <li><span class="check-icon"></span> Dedicated account manager</li>
          <li><span class="check-icon"></span> Fast 24-48 hr response time</li>
          <li><span class="check-icon"></span> Transparent pricing &amp; MOQs</li>
          <li><span class="check-icon"></span> Full regulatory compliance support</li>
        </ul>
      </div>

      <!-- Built-in Form Card which naturally fits right column -->
      <LeadFunnel format={formatName.toLowerCase()} />

    </div>
  </div>
</section>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
</style>
