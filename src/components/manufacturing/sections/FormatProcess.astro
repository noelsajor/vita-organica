---
interface ProcessStep {
  step: string;
  title: string;
  description: string;
  duration: string;
}

interface Props {
  processSteps: ProcessStep[];
}

const { processSteps } = Astro.props;
---

<section class="process-section" aria-labelledby="process-heading" style="background: var(--color-ink); color: var(--color-white); padding: 80px 0;">
  <div class="container">
    <header class="section-header">
      <span class="section-eyebrow" style="color: var(--color-green);">Production Timeline</span>
      <h2 id="process-heading" style="color: var(--color-white);">Manufacturing Process</h2>
    </header>

    <ol class="process-list" role="list" style="margin-top: 4rem;">
      {processSteps.map((step) => (
        <li class="process-step">
          <div class="step-header">
            <span class="step-num">{step.step}</span>
          </div>
          <div class="step-body">
            <h3 style="color: var(--color-white);">{step.title}</h3>
            <p style="color: var(--color-ink-muted);">{step.description}</p>
            <span class="step-duration" style="background: var(--color-ink-soft);">{step.duration}</span>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .process-step { border-left: 1px solid var(--color-ink-soft); }
  .step-num { background: var(--color-green); color: var(--color-ink); }
</style>
