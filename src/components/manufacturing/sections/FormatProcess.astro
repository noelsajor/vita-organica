---
interface Props {
  bg?: string;
}

const {
  bg = 'var(--color-white)'
} = Astro.props;
---

<section class="process-section" aria-labelledby="how-it-works-title" style={`background: ${bg};`}>
  <div class="container">
    <div class="process-grid">

      <!-- Left: sticky heading -->
      <div class="process-sticky">
        <span class="section-eyebrow">How It Works?</span>
        <h2 id="how-it-works-title">From Concept to Production Simplified</h2>
        <p>We've built a streamlined process so you can focus on your brand while we handle the complexity of manufacturing.</p>
        <a href="/request-quote" class="btn btn-primary">Request a Quote</a>
      </div>

      <!-- Right: scrollable steps -->
      <div class="process-steps" role="list" aria-label="How it works steps" data-reveal-stagger>

        <div class="process-step" role="listitem">
          <div class="step-track">
            <div class="step-num" aria-hidden="true">1</div>
            <div class="step-line"></div>
          </div>
          <div class="step-body">
            <h3>Consultation &amp; Strategy</h3>
            <p>Define your goals, target audience, and budget. We'll help you choose the right format and formulation path.</p>
            <span class="step-duration">Week 1</span>
          </div>
        </div>

        <div class="process-step" role="listitem">
          <div class="step-track">
            <div class="step-num" aria-hidden="true">2</div>
            <div class="step-line"></div>
          </div>
          <div class="step-body">
            <h3>Formulation &amp; Sampling</h3>
            <p>Develop a custom formula or choose from white label SKUs. You'll receive physical samples for approval.</p>
            <span class="step-duration">Weeks 2–3</span>
          </div>
        </div>

        <div class="process-step" role="listitem">
          <div class="step-track">
            <div class="step-num" aria-hidden="true">3</div>
            <div class="step-line"></div>
          </div>
          <div class="step-body">
            <h3>Design &amp; Compliance Review</h3>
            <p>FDA-compliant labeling and full regulatory review. Our team identifies potential regulatory hurdles early in the process.</p>
            <span class="step-duration">Weeks 3–4</span>
          </div>
        </div>

        <div class="process-step" role="listitem">
          <div class="step-track">
            <div class="step-num" aria-hidden="true">4</div>
            <div class="step-line"></div>
          </div>
          <div class="step-body">
            <h3>Production &amp; Quality Testing</h3>
            <p>Manufactured in our cGMP facility with rigorous QA protocols and third-party testing at every batch.</p>
            <span class="step-duration">Weeks 4–7</span>
          </div>
        </div>

        <div class="process-step" role="listitem">
          <div class="step-track">
            <div class="step-num" aria-hidden="true">5</div>
            <div class="step-line"></div>
          </div>
          <div class="step-body">
            <h3>Delivery &amp; Ongoing Scaling</h3>
            <p>Receive your finished products. We stay on as your manufacturing partner for reorders and new SKU growth.</p>
            <span class="step-duration">Week 8+</span>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>
