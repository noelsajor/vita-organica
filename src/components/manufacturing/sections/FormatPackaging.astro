---
interface PackagingOption {
  title: string;
  items: string[];
}

interface Props {
  packagingOptions: PackagingOption[];
}

const { packagingOptions } = Astro.props;
---

<section class="why-section" aria-labelledby="packaging-heading" style="padding: 80px 0;">
  <div class="container">
    <header class="section-header">
      <span class="section-eyebrow">Packaging & Fulfillment</span>
      <h2 id="packaging-heading">Retail-Ready Solutions</h2>
    </header>

    <ul class="packaging-grid" role="list" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(400px, 1fr)); gap: 3rem; margin-top: 3rem;">
      {packagingOptions.map((option) => (
        <li class="packaging-option" style="background: var(--color-white); padding: 32px; border: 1px solid var(--color-border); border-radius: var(--radius-lg);">
          <h3 style="margin-bottom: 1.5rem; color: var(--color-teal);">{option.title}</h3>
          <ul class="guide-checklist" role="list">
            {option.items.map((item) => (
              <li><span class="check-icon" aria-hidden="true"></span> {item}</li>
            ))}
          </ul>
        </li>
      ))}
    </ul>
  </div>
</section>
