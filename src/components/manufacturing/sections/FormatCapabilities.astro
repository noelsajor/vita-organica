---
interface Capability {
  title: string;
  description: string;
}

interface Props {
  formatName: string;
  capabilities: Capability[];
}

const { formatName, capabilities } = Astro.props;
---

<section class="manufacturing-section" aria-labelledby="capabilities-heading" style="background: var(--color-surface); padding: 80px 0;">
  <div class="container">
    <header class="section-header">
      <span class="section-eyebrow">Formulation Expertise</span>
      <h2 id="capabilities-heading">{formatName} Capabilities</h2>
    </header>

    <ul class="capabilities-grid" role="list" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem;">
      {capabilities.map((cap) => (
        <li class="bento-tile" style="padding: 2rem;">
          <h3>{cap.title}</h3>
          <p>{cap.description}</p>
        </li>
      ))}
    </ul>
  </div>
</section>
