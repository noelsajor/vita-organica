---
interface Capability {
  title: string;
  description: string;
}

interface Props {
  formatName: string;
  capabilities: Capability[];
}

const { formatName, capabilities } = Astro.props;

// Bento styling logic: assign specific classes based on index
const getBentoClass = (index: number) => {
  const patterns = ['large', 'medium', 'small', 'medium', 'small', 'small'];
  return patterns[index % patterns.length];
};

// Map items to icons (placeholder logic or generic icons)
const getIcon = (title: string) => {
  if (title.toLowerCase().includes('botanical') || title.toLowerCase().includes('premium')) {
    return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>`;
  }
  if (title.toLowerCase().includes('precision') || title.toLowerCase().includes('accuracy')) {
    return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>`;
  }
  return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`;
};
---

<section class="manufacturing-section" aria-labelledby="capabilities-heading" style="background: var(--color-white); padding: 120px 0;">
  <div class="container">
    <header class="section-header" style="margin-bottom: 5rem;">
      <span class="section-eyebrow">Formulation Expertise</span>
      <h2 id="capabilities-heading" style="font-size: 3rem;">{formatName} Capabilities</h2>
    </header>

    <div class="bento-grid-container">
      {capabilities.map((cap, index) => {
        const bentoClass = getBentoClass(index);
        return (
          <div class={`bento-item ${bentoClass}`}>
            <div class="bento-icon" set:html={getIcon(cap.title)} />
            <div class="bento-content">
              <h3>{cap.title}</h3>
              <p>{cap.description}</p>
            </div>
            <div class="bento-bg"></div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  .bento-grid-container {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 240px;
    gap: 1.5rem;
  }

  .bento-item {
    position: relative;
    border-radius: var(--radius-xl);
    overflow: hidden;
    background: var(--color-surface);
    border: 1px solid var(--color-border-light);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 2.5rem;
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .bento-item:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-lg);
    border-color: var(--color-teal);
  }

  .bento-icon {
    width: 32px;
    height: 32px;
    color: var(--color-teal);
    margin-bottom: 1.5rem;
    position: relative;
    z-index: 2;
  }

  /* Bento Spans */
  .large {
    grid-column: span 2;
    grid-row: span 2;
    background: var(--color-ink);
    color: var(--color-white);
    padding: 3.5rem;
  }

  .large .bento-icon {
    width: 48px;
    height: 48px;
    color: var(--color-green);
  }

  .large h3 {
    color: var(--color-white);
    font-size: 2.5rem;
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }

  .large p {
    color: rgba(255, 255, 255, 0.7);
    font-size: 1.2rem;
    max-width: 90%;
  }

  .medium {
    grid-column: span 2;
    grid-row: span 1;
  }

  .small {
    grid-column: span 1;
    grid-row: span 1;
  }

  /* Decorative Backgrounds */
  .large .bento-bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 70% 30%, rgba(143, 194, 20, 0.15) 0%, transparent 70%);
    pointer-events: none;
  }

  .medium {
    background: var(--color-white);
    border: 1px solid var(--color-border-light);
  }

  .small {
    background: var(--color-surface-alt);
  }

  .bento-content {
    position: relative;
    z-index: 2;
    margin-top: auto;
  }

  h3 {
    margin-bottom: 0.75rem;
    font-size: 1.4rem;
    letter-spacing: -0.02em;
  }

  p {
    font-size: 1rem;
    color: var(--color-ink-soft);
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 1024px) {
    .bento-grid-container {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: minmax(220px, auto);
    }
    .large h3 {
      font-size: 2rem;
    }
  }

  @media (max-width: 640px) {
    .bento-grid-container {
      grid-template-columns: 1fr;
      grid-auto-rows: auto;
    }
    .large, .medium, .small {
      grid-column: span 1;
      grid-row: span 1;
    }
    .bento-item {
      padding: 2rem;
    }
  }
</style>
