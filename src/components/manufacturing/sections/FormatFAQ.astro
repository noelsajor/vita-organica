---
// src/components/manufacturing/sections/FormatFAQ.astro
interface FAQ {
  question: string;
  answer: string;
}

interface Props {
  faqs: FAQ[];
  bg?: string;
}

const { faqs, bg = 'var(--color-white)' } = Astro.props;
---

<section class="section-padding" style={`padding: 80px 0; background: ${bg};`}>
  <div class="container">
    <div class="section-header">
      <span class="section-eyebrow">Common Questions</span>
      <h2>Frequently Asked Questions</h2>
    </div>
    
    <div style="max-width: 800px; margin: 0 auto;">
      {faqs.map(faq => (
        <details style="margin-bottom: 1rem; border-bottom: 1px solid var(--color-border); padding-bottom: 1rem;">
          <summary style="font-weight: 600; cursor: pointer; padding: 0.5rem 0; font-family: var(--font-heading); font-size: 1.1rem;">
            {faq.question}
          </summary>
          <p style="margin-top: 0.5rem; color: var(--color-ink-soft); line-height: 1.6;">
            {faq.answer}
          </p>
        </details>
      ))}
    </div>
  </div>
</section>
