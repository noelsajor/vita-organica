---
// src/components/manufacturing/sections/FormatProductNav.astro
const products = [
  { label: "Gummies", href: "/manufacturing/gummies", active: true },
  { label: "Powders", href: "/manufacturing/powders", active: true },
  { label: "Honey Spoons", href: "/manufacturing/spoons", active: true },
  { label: "Honey Gels", href: "/manufacturing/gel", active: true },
  { label: "Capsules", href: "/manufacturing/capsules", active: true }
];

const { currentFormat } = Astro.props;

const isMatch = (current: string, label: string) => {
  if (!current) return false;
  const c = current.toLowerCase().trim();
  const l = label.toLowerCase().trim();
  
  // Supplement-specific mappings (singular to plural & alternative names)
  const mappings: Record<string, string[]> = {
    'gummies': ['gummy', 'gummies'],
    'powders': ['powder', 'powders'],
    'honey spoons': ['spoon', 'spoons', 'honey spoon', 'stick pack'],
    'honey gels': ['gel', 'gels', 'honey gel', 'specialty gel'],
    'capsules': ['capsule', 'capsules']
  };

  // Check if our current format matches any of the mapped values for this label
  if (mappings[l]?.some(m => c.includes(m) || m.includes(c))) return true;

  // Final containment fallback
  return l.includes(c) || c.includes(l);
};
---

<section class="manufacturing-section" style="padding: 60px 0; background: var(--color-surface-alt);">
  <div class="container">
    <div class="section-header" style="text-align: center; margin-bottom: 2rem;">
      <span class="section-eyebrow">Product Types</span>
      <h2>Specialized Delivery Systems</h2>
    </div>
    <div style="display: flex; gap: 0.75rem; overflow-x: auto; padding-bottom: 1rem; justify-content: center; -webkit-overflow-scrolling: touch; flex-wrap: wrap;">
      {products.map(product => {
        const activeState = isMatch(currentFormat, product.label);
        
        return product.active ? (
          <a 
            href={product.href} 
            class={`nav-nav-pill ${activeState ? 'active' : ''}`} 
            style={`
              flex: 0 0 auto;
              min-width: 120px;
              text-align: center; 
              text-decoration: none; 
              padding: 0.75rem 1.5rem; 
              border-radius: var(--radius-pill);
              border: 1px solid ${activeState ? 'var(--color-ink)' : 'var(--color-border)'};
              background: ${activeState ? 'var(--color-ink)' : 'var(--color-white)'};
              transition: all 0.2s ease;
            `}
          >
            <span style={`
              margin: 0; 
              font-size: 0.95rem; 
              font-weight: 600;
              color: ${activeState ? 'var(--color-white)' : 'var(--color-ink-soft)'};
            `}>
              {product.label}
            </span>
          </a>
        ) : (
          <div 
            class="nav-nav-pill-disabled" 
            style={`
              flex: 0 0 auto;
              min-width: 120px;
              text-align: center; 
              opacity: 0.4; 
              padding: 0.75rem 1.5rem; 
              background: var(--color-surface); 
              border: 1px dashed var(--color-border);
              border-radius: var(--radius-pill);
            `}
          >
            <span style="margin:0; font-size:0.95rem; font-weight: 600; color: var(--color-ink-muted);">{product.label}</span>
          </div>
        )
      })}
    </div>
  </div>
</section>
