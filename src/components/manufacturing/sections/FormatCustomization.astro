---
// src/components/manufacturing/sections/FormatCustomization.astro
interface Option {
  title: string;
  description: string;
}

interface Props {
  formatName: string;
  options: Option[];
  bg?: string;
}

const { formatName, options, bg = 'var(--color-white)' } = Astro.props;
---

<section class="who-section" style={`padding: 80px 0; background: ${bg};`}>
  <div class="container">
    <div class="section-header">
      <span class="section-eyebrow">Customization Options</span>
      <h2>Tailor-Made {formatName} Formulations</h2>
      <p class="section-subhead">Build a product that truly represents your brand with our extensive customization capabilities.</p>
    </div>
    
    <div class="who-grid">
      {options.map(option => (
        <div class="who-card">
          <div class="who-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <h3>{option.title}</h3>
          <p>{option.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
