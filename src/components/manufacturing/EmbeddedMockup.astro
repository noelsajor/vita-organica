---
// src/components/manufacturing/EmbeddedMockup.astro
import MockupGenerator from '../MockupGenerator';

interface Props {
  formatName: string;
}

const { formatName } = Astro.props;
---

<section class="section-padding" style="padding: 80px 0; background: var(--color-white);">
  <div class="container">
    <div class="section-header">
      <span class="section-eyebrow">Visual Experience</span>
      <h2>Visualize Your {formatName} Product</h2>
      <p>See what your branding will look like on our premium, retail-ready formats instantly.</p>
    </div>
    
    <div class="mockup-embed-wrapper" style="border: 1px solid var(--color-border); border-radius: var(--radius-lg); overflow: hidden; background: var(--color-surface-alt);">
      <MockupGenerator client:visible />
    </div>
  </div>
</section>
