---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormatHero from './sections/FormatHero.astro';
import FormatProof from './sections/FormatProof.astro';
import FormatFunnelSlot from './sections/FormatFunnelSlot.astro';
import FormatBenefits from './sections/FormatBenefits.astro';
import FormatCapabilities from './sections/FormatCapabilities.astro';
import FormatPackaging from './sections/FormatPackaging.astro';
import FormatProcess from './sections/FormatProcess.astro';
import MockupTeaser from './sections/MockupTeaser.astro';

interface Benefit {
  title: string;
  description: string;
  icon?: string;
}

interface Capability {
  title: string;
  description: string;
}

interface PackagingOption {
  title: string;
  items: string[];
}

interface ProcessStep {
  step: string;
  title: string;
  description: string;
  duration: string;
}

interface ProofStat {
  num: string;
  label: string;
}

interface Props {
  formatName: string;
  heroTitle: string;
  heroDescription: string;
  benefits: Benefit[];
  capabilities: Capability[];
  packagingOptions: PackagingOption[];
  processSteps: ProcessStep[];
  proofStats: ProofStat[];
  canonical?: string;
  showMockupTeaser?: boolean;
  mockupHref?: string;
}

const {
  formatName,
  heroTitle,
  heroDescription,
  benefits,
  capabilities,
  packagingOptions,
  processSteps,
  proofStats,
  canonical,
  showMockupTeaser = false,
  mockupHref = "/mockup"
} = Astro.props;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": `${formatName} Manufacturing`,
  "description": heroDescription,
  "provider": {
    "@type": "Organization",
    "name": "Vita Organica"
  },
  "serviceType": "Supplement Manufacturing",
  "areaServed": "US",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Manufacturing Formats",
    "itemListElement": capabilities.map(cap => ({
      "@type": "Offer",
      "itemOffered": {
        "@type": "Service",
        "name": cap.title,
        "description": cap.description
      }
    }))
  }
};
---

<BaseLayout 
  title={`${formatName} Manufacturing | Vita Organica`} 
  description={heroDescription}
  canonical={canonical}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <main id="main-content">
    <article class="format-detail">
      
      <FormatHero 
        formatName={formatName} 
        heroTitle={heroTitle} 
        heroDescription={heroDescription} 
      />

      <FormatProof 
        formatName={formatName} 
        proofStats={proofStats} 
      />

      <FormatFunnelSlot 
        formatName={formatName} 
      />

      <FormatBenefits 
        formatName={formatName} 
        benefits={benefits} 
      />

      <FormatCapabilities 
        formatName={formatName} 
        capabilities={capabilities} 
      />

      <FormatPackaging 
        packagingOptions={packagingOptions} 
      />

      {showMockupTeaser && (
        <MockupTeaser href={mockupHref} />
      )}

      <FormatProcess 
        processSteps={processSteps} 
      />

      {/* ── RELATED FORMATS SLOT ── */}
      <section class="related-formats-section" aria-labelledby="related-heading" style="padding: 80px 0; background: var(--color-white);">
        <div class="container">
          <slot name="related-formats">
            <div style="text-align: center; border: 1px dashed var(--color-border); padding: 40px; border-radius: var(--radius-lg);">
              <h2 id="related-heading" class="sr-only">Related Manufacturing Formats</h2>
              <p style="color: var(--color-ink-muted);">Explore other manufacturing delivery systems to diversify your product line.</p>
              <a href="/manufacturing" class="text-link" style="margin-top: 1rem; display: inline-block;">View All Capabilities →</a>
            </div>
          </slot>
        </div>
      </section>

      <footer class="final-cta-section" style="padding: 100px 0; background: var(--color-surface); text-align: center;">
        <div class="container">
          <h2>Ready to Scale Your {formatName} Brand?</h2>
          <p style="margin: 1.5rem 0 2rem; color: var(--color-ink-soft);">Join 500+ brands that trust Vita Organica for premium manufacturing.</p>
          <a href="/request-quote" class="btn btn-primary btn-lg">Request a Custom Quote</a>
        </div>
      </footer>

    </article>
  </main>
</BaseLayout>

<style>
  .format-detail {
    display: block;
    width: 100%;
  }
  
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
</style>
