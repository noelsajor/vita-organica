<script>
  (function() {
    /* ── Sticky header shadow ── */
    const header = document.querySelector('.site-header');
    window.addEventListener('scroll', () => {
      header.classList.toggle('scrolled', window.scrollY > 10);
    }, { passive: true });

    /* ── Mobile menu ── */
    const menuBtn = document.querySelector('.mobile-menu-toggle');
    const mobileNav = document.getElementById('mobile-nav');
    if (menuBtn && mobileNav) {
      menuBtn.addEventListener('click', () => {
        const isOpen = mobileNav.classList.toggle('is-open');
        menuBtn.setAttribute('aria-expanded', String(isOpen));
        menuBtn.setAttribute('aria-label', isOpen ? 'Close menu' : 'Open menu');
      });
    }

    /* ── Desktop dropdowns ── */
    document.querySelectorAll('.main-nav .dropdown-toggle').forEach(btn => {
      const parent = btn.closest('.has-dropdown');
      const setExp = v => btn.setAttribute('aria-expanded', String(v));
      btn.addEventListener('click', e => {
        e.preventDefault();
        const open = btn.getAttribute('aria-expanded') === 'true';
        setExp(!open);
        parent.classList.toggle('open', !open);
      });
      parent.addEventListener('focusout', e => {
        if (!parent.contains(e.relatedTarget)) { parent.classList.remove('open'); setExp(false); }
      });
      btn.addEventListener('keydown', e => {
        if (e.key === 'Escape') { parent.classList.remove('open'); setExp(false); btn.blur(); }
      });
      document.addEventListener('click', e => {
        if (!parent.contains(e.target)) { parent.classList.remove('open'); setExp(false); }
      });
    });

    /* ── Mobile submenus ── */
    document.querySelectorAll('.mobile-dropdown-toggle').forEach(btn => {
      btn.addEventListener('click', () => {
        const open = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', String(!open));
        const id = btn.getAttribute('aria-controls');
        document.getElementById(id)?.classList.toggle('is-open', !open);
      });
    });
  })();
</script>
